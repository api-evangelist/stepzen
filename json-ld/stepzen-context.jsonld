{
  "@context": {
    "@version": 1.1,
    "stepzen": "https://stepzen.com/vocab/",
    "schema": "https://schema.org/",
    "Endpoint": {
      "@id": "stepzen:Endpoint",
      "@type": "@id"
    },
    "ApiKey": {
      "@id": "stepzen:ApiKey",
      "@type": "@id"
    },
    "Account": {
      "@id": "stepzen:Account",
      "@type": "@id"
    },
    "id": "@id",
    "name": "schema:name",
    "description": "schema:description",
    "url": "schema:url",
    "folder": "stepzen:schemaFolder",
    "status": "stepzen:deploymentStatus",
    "createdAt": "schema:dateCreated",
    "updatedAt": "schema:dateModified",
    "key": "stepzen:apiKey",
    "type": "schema:additionalType",
    "plan": "schema:priceSpecification",
    "endpointCount": "stepzen:endpointCount",
    "requestsThisMonth": "stepzen:monthlyRequests",
    "email": "schema:email"
  }
}
